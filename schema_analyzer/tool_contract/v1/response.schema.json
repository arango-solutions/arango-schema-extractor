{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arangodb.com/schema-analyzer/tool-contract/v1/response.schema.json",
  "title": "ArangoDB Schema Analyzer Tool Response (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "operation", "ok"],
  "properties": {
    "contractVersion": { "const": "1" },
    "requestId": { "type": "string" },
    "operation": { "type": "string", "enum": ["analyze", "snapshot", "export", "docs", "owl", "diff", "resolve"] },
    "ok": { "type": "boolean" },

    "tooling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "libraryVersion": { "type": "string" },
        "contractVersion": { "type": "string" },
        "snapshotFingerprint": { "type": "string" },
        "snapshotVersion": { "type": "integer" },
        "usedBaseline": { "type": "boolean" },
        "repairAttempts": { "type": "integer", "minimum": 0 },
        "runId": { "type": "string", "description": "Analysis run UUID when operation was analyze" },
        "physicalSchemaFingerprint": {
          "type": "string",
          "description": "SHA-256 of normalized physical snapshot (analyze tooling mirror of metadata)"
        },
        "cacheHit": { "type": "boolean", "description": "True when analyze result was served from cache" }
      }
    },

    "result": {
      "description": "Operation-specific payload.",
      "oneOf": [
        { "$ref": "#/$defs/AnalyzeResult" },
        { "$ref": "#/$defs/SnapshotResult" },
        { "$ref": "#/$defs/ExportResult" },
        { "$ref": "#/$defs/DocsResult" },
        { "$ref": "#/$defs/OwlResult" },
        { "$ref": "#/$defs/DiffResult" },
        { "$ref": "#/$defs/ResolveResult" }
      ]
    },

    "error": {
      "type": "object",
      "additionalProperties": true,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  },

  "$defs": {
    "AnalysisOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conceptualSchema", "physicalMapping", "metadata"],
      "properties": {
        "conceptualSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entities", "relationships", "properties"],
          "properties": {
            "entities": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "labels": { "type": "array", "items": { "type": "string" } },
                  "properties": { "type": "array", "items": { "type": "object" } },
                  "source": { "$ref": "#/$defs/ElementSource" }
                }
              }
            },
            "relationships": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "fromEntity", "toEntity"],
                "properties": {
                  "type": { "type": "string", "minLength": 1 },
                  "fromEntity": { "type": "string", "minLength": 1 },
                  "toEntity": { "type": "string", "minLength": 1 },
                  "properties": { "type": "array", "items": { "type": "object" } },
                  "source": { "$ref": "#/$defs/ElementSource" }
                }
              }
            },
            "properties": { "type": "array", "items": { "type": "object" } }
          }
        },
        "physicalMapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entities", "relationships"],
          "properties": {
            "shardFamilies": {
              "type": "array",
              "description": "Groups of structurally-identical entities that share a common name suffix (PRD §6.2 bullet 5). Empty array means detection ran and found none.",
              "items": { "$ref": "#/$defs/ShardFamily" }
            },
            "entities": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["style"],
                "properties": {
                  "style": { "type": "string", "enum": ["COLLECTION", "LABEL"] },
                  "collectionName": { "type": "string" },
                  "typeField": { "type": "string" },
                  "typeValue": { "type": "string" },
                  "indexes": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["type", "fields"],
                      "properties": {
                        "type": { "type": "string" },
                        "fields": { "type": "array", "items": { "type": "string" } },
                        "unique": { "type": "boolean" },
                        "sparse": { "type": "boolean" },
                        "name": { "type": "string" },
                        "vci": { "type": "boolean" },
                        "deduplicate": { "type": "boolean" },
                        "storedValues": { "type": "array", "items": { "type": "string" } }
                      }
                    }
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": ["field"],
                      "properties": {
                        "field": { "type": "string" },
                        "indexed": { "type": "boolean" },
                        "unique": { "type": "boolean" }
                      }
                    }
                  },
                  "tenantScope": { "$ref": "#/$defs/TenantScope" },
                  "source": { "$ref": "#/$defs/ElementSource" },
                  "tripleCandidate": { "type": "boolean" },
                  "triple": { "$ref": "#/$defs/Triple" }
                }
              }
            },
            "relationships": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "required": ["style"],
                "not": { "required": ["collectionName"] },
                "properties": {
                  "style": { "type": "string", "enum": ["DEDICATED_COLLECTION", "GENERIC_WITH_TYPE"] },
                  "edgeCollectionName": { "type": "string" },
                  "typeField": { "type": "string" },
                  "typeValue": { "type": "string" },
                  "indexes": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["type", "fields"],
                      "properties": {
                        "type": { "type": "string" },
                        "fields": { "type": "array", "items": { "type": "string" } },
                        "unique": { "type": "boolean" },
                        "sparse": { "type": "boolean" },
                        "name": { "type": "string" },
                        "vci": { "type": "boolean" },
                        "deduplicate": { "type": "boolean" },
                        "storedValues": { "type": "array", "items": { "type": "string" } }
                      }
                    }
                  },
                  "properties": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": ["field"],
                      "properties": {
                        "field": { "type": "string" },
                        "indexed": { "type": "boolean" },
                        "unique": { "type": "boolean" }
                      }
                    }
                  },
                  "vci": { "$ref": "#/$defs/Vci" },
                  "vciCandidate": {
                    "type": "boolean",
                    "description": "True when a vertex-centric-index pattern (index-level and/or denormalization) was detected for this relationship (PRD §6.1/§6.2). The underlying style is preserved; this is an additive optimization hint."
                  },
                  "source": { "$ref": "#/$defs/ElementSource" },
                  "tripleCandidate": { "type": "boolean" },
                  "triple": { "$ref": "#/$defs/Triple" }
                }
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["confidence", "timestamp", "analyzedCollectionCounts", "detectedPatterns"],
          "properties": {
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "timestamp": { "type": "string" },
            "analyzedCollectionCounts": {
              "type": "object",
              "additionalProperties": false,
              "required": ["documentCollections", "edgeCollections"],
              "properties": {
                "documentCollections": { "type": "number", "minimum": 0 },
                "edgeCollections": { "type": "number", "minimum": 0 }
              }
            },
            "detectedPatterns": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } },
            "assumptions": { "type": "array", "items": { "type": "string" } },
            "tenantScopeReport": {
              "description": "Summary of per-entity tenant-scope classification applied to physicalMapping.entities[*].tenantScope. Null (or absent) when no tenant-root entity was detected — single-tenant graphs leave it null. Mirrors the null-default convention used by sibling diagnostic blocks (reconciliation, statistics).",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["tenantEntity"],
                  "properties": {
                    "tenantEntity": { "type": "string", "minLength": 1 },
                    "denormScopedCount": { "type": "integer", "minimum": 0 },
                    "traversalScopedCount": { "type": "integer", "minimum": 0 },
                    "globalCount": { "type": "integer", "minimum": 0 },
                    "tenantFieldRegex": { "type": "string" },
                    "discovery": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "fromExplicitAnnotation": { "type": "integer", "minimum": 0 },
                        "fromDenormFieldHeuristic": { "type": "integer", "minimum": 0 },
                        "fromTraversalReachability": { "type": "integer", "minimum": 0 }
                      }
                    }
                  }
                }
              ]
            },
            "shardingProfile": { "$ref": "#/$defs/ShardingProfile" },
            "shardingProfileStatus": {
              "description": "Mirror of shardingProfile.status for callers that only want to branch on ok/degraded without reading the full block. Absent when shardingProfile is absent (snapshot too minimal to classify).",
              "oneOf": [
                { "type": "null" },
                { "type": "string", "enum": ["ok", "degraded"] }
              ]
            },
            "multitenancy": { "$ref": "#/$defs/Multitenancy" },
            "multitenancyStatus": {
              "description": "Mirror of multitenancy.status for callers that only want to branch on ok/degraded without reading the full block. Absent when multitenancy is absent (snapshot has no user collections).",
              "oneOf": [
                { "type": "null" },
                { "type": "string", "enum": ["ok", "degraded"] }
              ]
            },
            "vci": {
              "description": "Summary of vertex-centric-index detection (PRD §6.1/§6.2): the relationship types for which a VCI pattern was found. Per-relationship detail lives under physicalMapping.relationships[type].vci. Null when no VCI signals were found.",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "relationships": { "type": "array", "items": { "type": "string" } }
                  }
                }
              ]
            },
            "rdfTopology": {
              "description": "RDF-topology (RPT) classification (PRD §6.1/§6.2): whether the schema is stored as RDF triples / rdf:type edges (the TRIPLE mapping style). Triple/type collections are also annotated under physicalMapping with tripleCandidate=true. Null when the snapshot has no collections to classify.",
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "isRdfTopology": { "type": "boolean" },
                    "tripleCollections": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                    "typeEdges": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
                    "evidence": { "type": "array", "items": { "type": "string" } }
                  }
                }
              ]
            },
            "qualityMetrics": {
              "description": "Deterministic structural + grounding quality signals (PRD 3.12.3). Structural metrics are derived from the conceptual schema (connectivity, orphan ratio, property richness, dangling-relationship consistency); grounding metrics check the physical mapping against the snapshot (every referenced collection exists; every entity is mapped). Ratios are null when their denominator is zero.",
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "structural": { "type": "object", "additionalProperties": true },
                "grounding": { "type": "object", "additionalProperties": true },
                "healthScoreComponents": { "type": "object", "additionalProperties": { "type": "number" } }
              }
            },
            "healthScore": {
              "description": "Normalized 0-100 composite that folds confidence with the structural connectivity/consistency and mapping-grounding signals. Components that are not applicable for a given schema (e.g. connectivity for a relationship-free schema) are dropped and the remaining weights renormalized.",
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      }
    },

    "ShardingProfile": {
      "description": "Deployment-style classification for the analyzed database. Emitted when snapshot_physical_schema yielded at least one user collection; absent (null) when the snapshot is too minimal to classify. Primary style is exclusive (exactly one of OneShard / DisjointSmartGraph / SmartGraph / SatelliteGraph / Sharded); per-graph and per-collection evidence is always populated so downstream consumers can reason about shard boundaries without re-deriving them.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["style", "status"],
          "properties": {
            "style": {
              "type": "string",
              "enum": [
                "OneShard",
                "DisjointSmartGraph",
                "SmartGraph",
                "SatelliteGraph",
                "Sharded"
              ]
            },
            "status": { "type": "string", "enum": ["ok", "degraded"] },
            "statusReason": { "type": "string" },
            "database": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "sharding": { "type": "string" },
                "replicationFactor": { "type": ["integer", "string"] },
                "writeConcern": { "type": "integer", "minimum": 0 }
              }
            },
            "collectionKindCounts": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "smartgraph": { "type": "integer", "minimum": 0 },
                "satellite": { "type": "integer", "minimum": 0 },
                "regular": { "type": "integer", "minimum": 0 }
              }
            },
            "graphs": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "isSmart": { "type": "boolean" },
                  "isDisjoint": { "type": "boolean" },
                  "isSatellite": { "type": "boolean" },
                  "smartGraphAttribute": { "type": "string" },
                  "vertexCollections": { "type": "array", "items": { "type": "string" } },
                  "edgeCollections": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "satelliteCollections": {
              "type": "array",
              "items": { "type": "string" }
            },
            "oneShardLeader": { "type": "string" },
            "collections": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": true,
                "required": ["kind"],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": ["smartgraph", "satellite", "regular"]
                  },
                  "numberOfShards": { "type": "integer", "minimum": 1 },
                  "shardKeys": { "type": "array", "items": { "type": "string" } },
                  "shardingStrategy": { "type": "string" },
                  "replicationFactor": { "type": ["integer", "string"] },
                  "writeConcern": { "type": "integer", "minimum": 0 },
                  "minReplicationFactor": { "type": "integer", "minimum": 0 },
                  "distributeShardsLike": { "type": ["string", "null"] },
                  "smartGraphAttribute": { "type": "string" },
                  "isSmart": { "type": "boolean" },
                  "isDisjoint": { "type": "boolean" },
                  "isSatellite": { "type": "boolean" },
                  "graphName": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    },

    "ShardFamily": {
      "type": "object",
      "description": "A group of structurally-identical entities (same property set) whose conceptual names share a common suffix (PRD §6.2 bullet 5). Captures the per-source / per-repository / per-stream collection-duplication pattern. NOT multitenancy (structural duplication, not per-customer isolation). Downstream consumers (NL→Cypher prompt builders, UI mapping panels) use the family grouping to emit UNION-aware guidance instead of silently picking one member.",
      "additionalProperties": false,
      "required": ["name", "suffix", "discriminator", "sharedProperties", "members"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Family label, derived from the common suffix with any leading underscore stripped (e.g. \"Document\" from suffix \"Document\")."
        },
        "suffix": {
          "type": "string",
          "minLength": 1,
          "description": "The verbatim common suffix shared by every member's conceptual name (e.g. \"Document\", \"_Golden_Entities\")."
        },
        "discriminator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source"],
          "properties": {
            "source": {
              "type": "string",
              "enum": ["field", "collection_prefix"],
              "description": "\"field\" when every member declares a candidate discriminator property (see SHARD_FAMILY_DISCRIMINATOR_FIELDS in defaults). \"collection_prefix\" otherwise — discriminatorValue then comes from the prefix portion of each member's conceptual name."
            },
            "field": {
              "type": "string",
              "description": "Required when source == \"field\". The property name carried by every member that distinguishes shards (e.g. \"repo\")."
            }
          }
        },
        "sharedProperties": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sorted property-name list common to all members. Identical to each member's property names by construction (the bucket key is the hash of this list)."
        },
        "members": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entity", "collectionName", "discriminatorValue"],
            "properties": {
              "entity": {
                "type": "string",
                "description": "Conceptual entity name (key in physicalMapping.entities)."
              },
              "collectionName": {
                "type": "string",
                "description": "Underlying ArangoDB collection name."
              },
              "discriminatorValue": {
                "type": "string",
                "description": "The portion of the entity name preceding the family suffix (e.g. \"IBEX\" for \"IBEXDocument\" with suffix \"Document\"). Empty string is permitted in the degenerate case where the entity name equals the suffix."
              }
            }
          }
        }
      }
    },

    "Multitenancy": {
      "description": "Multitenancy classification for the analyzed database (PRD §6.2 bullet 4). Layers on top of shardingProfile: when shardingProfile.style == \"DisjointSmartGraph\" the smart attribute is the tenant key with physicalEnforcement=true. Otherwise the analyzer probes shard keys, candidate discriminator fields, collection naming patterns, and the database name in priority order. Absent (null) when the snapshot has no user collections.",
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["style", "status", "physicalEnforcement", "tenantKey", "evidence"],
          "properties": {
            "style": {
              "type": "string",
              "enum": [
                "none",
                "disjoint_smartgraph",
                "shard_key",
                "discriminator_field",
                "collection_per_tenant",
                "database_per_tenant",
                "unknown_single_db"
              ],
              "description": "Exclusive tenancy-style classification. \"none\" means no signal triggered (single-tenant database). \"unknown_single_db\" is a hint that this single-database snapshot looks tenant-named; an orchestrator must confirm by aggregating across databases."
            },
            "status": { "type": "string", "enum": ["ok", "degraded"] },
            "physicalEnforcement": {
              "type": "boolean",
              "description": "true when tenant isolation is enforced by the storage layer (shard key, smart graph, per-tenant collection / database). false for discriminator_field — convention only, application code must enforce."
            },
            "tenantKey": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Property name(s) that identify a tenant (e.g. [\"tenantId\"], [\"smartAttr\"]). Empty when the style does not surface a single key (e.g. collection_per_tenant)."
            },
            "tenantKeyCollections": {
              "type": "array",
              "description": "Per-collection evidence that the tenant key was observed. Populated by shard_key and discriminator_field styles; omitted otherwise.",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["collection"],
                "properties": {
                  "collection": { "type": "string" },
                  "field": { "type": "string" },
                  "shardKey": { "type": "string" },
                  "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
                  "distinctValues": { "type": "integer", "minimum": 0 },
                  "sampleValues": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "evidence": {
              "type": "object",
              "description": "Free-form, style-specific signals that drove the classification. Always present so downstream consumers can audit / override. Shape varies by style; consumers should treat unknown keys as additive.",
              "additionalProperties": true
            }
          }
        }
      ]
    },

    "TenantScope": {
      "type": "object",
      "description": "Per-entity tenant-isolation classification. Tells downstream consumers (transpilers, NL\u2192Cypher pipelines) how to enforce tenant boundaries when querying this collection. Operators may set this explicitly to override heuristic detection; explicit annotations always win.",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["tenant_root", "tenant_scoped", "global"],
          "description": "tenant_root: anchors the tenant hierarchy (typically the Tenant collection itself). tenant_scoped: belongs to a single tenant; query MUST constrain to one tenant either via the denormalised tenantField or via traversal from the tenant root. global: cross-tenant reference data (e.g. CVE, AppVersion); queries MUST NOT include any tenant filter."
        },
        "tenantField": {
          "type": "string",
          "description": "When role is tenant_scoped and the entity carries a denormalised tenant reference, the field name (e.g. TENANT_ID). Consumers should filter on this field with the tenant key for efficient single-collection queries. Omit for traversal-only scoped entities."
        },
        "tenantEntity": {
          "type": "string",
          "description": "Conceptual name of the tenant root for this scoping (typically Tenant). Required when role is tenant_scoped; omitted for tenant_root and global."
        }
      }
    },

    "AnalyzeResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysis"],
      "properties": {
        "analysis": { "$ref": "#/$defs/AnalysisOutput" },
        "snapshot": { "type": "object", "additionalProperties": true }
      }
    },

    "SnapshotResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["snapshot"],
      "properties": {
        "snapshot": { "type": "object", "additionalProperties": true }
      }
    },

    "ExportResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["export"],
      "properties": {
        "export": {
          "oneOf": [
            { "$ref": "#/$defs/AnalysisOutput" },
            { "$ref": "#/$defs/SparqlExport" }
          ]
        }
      }
    },

    "Vci": {
      "description": "Vertex-centric-index signals for a relationship (PRD §6.1/§6.2).",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "indexLevel": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "accessPattern": { "type": "string", "enum": ["out-edge", "in-edge", "both"] },
            "indexes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "root": { "type": "string", "enum": ["_from", "_to"] },
                  "fields": { "type": "array", "items": { "type": "string" } },
                  "discriminatorFields": { "type": "array", "items": { "type": "string" } },
                  "unique": { "type": "boolean" },
                  "sparse": { "type": "boolean" }
                }
              }
            }
          }
        },
        "denormalization": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "duplicatedFields": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "field": { "type": "string" },
                  "sourceCollections": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },

    "Triple": {
      "description": "TRIPLE mapping-style annotation (PRD §6.1/§6.2): this entity/relationship is stored in an RDF triple/quad collection rather than as a native property-graph collection.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "style": { "const": "TRIPLE" }
      }
    },

    "ElementSource": {
      "description": "Provenance tag (PRD 3.13.2) marking which producer emitted this element: 'llm' (generate/validate/repair loop), 'baseline' (deterministic inference, including reconciliation backfill on an LLM run), or 'human' (curated and preserved across re-analysis).",
      "type": "string",
      "enum": ["llm", "baseline", "human"]
    },

    "SparqlExport": {
      "type": "object",
      "additionalProperties": true,
      "required": ["target", "prefixes", "classes", "objectProperties"],
      "properties": {
        "target": { "const": "sparql" },
        "prefixes": { "type": "object", "additionalProperties": { "type": "string" } },
        "classes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["iri", "localName", "label"],
            "properties": {
              "iri": { "type": "string" },
              "localName": { "type": "string" },
              "label": { "type": "string" },
              "physical": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "objectProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["iri", "localName", "label"],
            "properties": {
              "iri": { "type": "string" },
              "localName": { "type": "string" },
              "label": { "type": "string" },
              "domain": { "type": "string" },
              "range": { "type": "string" },
              "physical": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "datatypeProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["iri", "localName", "label"],
            "properties": {
              "iri": { "type": "string" },
              "localName": { "type": "string" },
              "label": { "type": "string" },
              "domain": { "type": "string" },
              "attribute": { "type": "string" },
              "physical": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "physicalMapping": { "type": "object", "additionalProperties": true }
      }
    },

    "DocsResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["markdown"],
      "properties": {
        "markdown": { "type": "string" }
      }
    },

    "OwlResult": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["turtle"] },
        { "required": ["jsonld"] }
      ],
      "properties": {
        "turtle": { "type": "string" },
        "jsonld": {
          "type": "object",
          "additionalProperties": true,
          "description": "JSON-LD serialization of the conceptual OWL model (classes, subClassOf hierarchy, object properties with domain/range, observed cardinality + functional/inverse-functional characteristics, owl:inverseOf, and phys: annotations)."
        }
      }
    },

    "DiffResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["diff"],
      "properties": {
        "diff": {
          "type": "object",
          "additionalProperties": true,
          "description": "Structural diff between input.previousAnalysis and input.analysis (PRD §3.13.3): added/removed/changed entities & relationships, mapping-style flips, and the health-score delta.",
          "required": ["changed", "entities", "relationships", "mappingStyles"],
          "properties": {
            "changed": { "type": "boolean" },
            "entities": { "type": "object", "additionalProperties": true },
            "relationships": { "type": "object", "additionalProperties": true },
            "mappingStyles": { "type": "object", "additionalProperties": true },
            "healthScore": { "type": "object", "additionalProperties": true },
            "summary": { "type": "object", "additionalProperties": true }
          }
        }
      }
    },

    "ResolveResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolution"],
      "properties": {
        "resolution": {
          "type": "object",
          "additionalProperties": true,
          "description": "Flattened label/relationship-type → AQL lookup for a Cypher transpiler (build_cypher_resolution_index): per entity the injection-safe match fragment, per relationship the traversal fragment, or an error block for incomplete mappings.",
          "properties": {
            "target": { "const": "cypher" },
            "entities": { "type": "object", "additionalProperties": true },
            "relationships": { "type": "object", "additionalProperties": true }
          }
        }
      }
    }
  },

  "allOf": [
    {
      "if": { "properties": { "ok": { "const": true } } },
      "then": { "required": ["result"] },
      "else": { "required": ["error"] }
    }
  ]
}

