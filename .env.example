## Copy to .env and fill in values
## IMPORTANT: Do not commit .env

# ArangoDB connection (used by integration tests, eval harness, and the CLI).
# These names match the CI workflow, README, and CONTRIBUTING examples.
# `ARANGO_HOST` and `ARANGO_PASSWORD` are also accepted as fallbacks.
ARANGO_URL=http://localhost:18529
ARANGO_DB=schema_analyzer_it
ARANGO_USER=root
ARANGO_PASS=openSesame
ARANGO_NO_AUTH=false

# LLM provider API keys (only set the one(s) you intend to use)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
