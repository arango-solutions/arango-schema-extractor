## Copy to .env and fill in values
## IMPORTANT: Do not commit .env

# ArangoDB connection (used by integration tests, eval harness, and the CLI).
# These names match the CI workflow, README, and CONTRIBUTING examples.
#
# Fallback scope (CLI ONLY): the `eval` and `tool` CLI subcommands also
# read `ARANGO_HOST` / `ARANGO_PASSWORD` if `ARANGO_URL` / `ARANGO_PASS`
# are unset. The library API and the v1 tool contract use only the
# request/`*EnvVar` fields they are given; they do NOT fall back to
# `ARANGO_HOST` / `ARANGO_PASSWORD`. Prefer the primary names.
ARANGO_URL=http://localhost:18529
ARANGO_DB=schema_analyzer_it
ARANGO_USER=root
ARANGO_PASS=openSesame
ARANGO_NO_AUTH=false

# Optional operator-side hardening for the v1 tool contract. Both default
# to off (preserving CLI ergonomics). See docs/tool-contract/v1/README.md.
# SCHEMA_ANALYZER_ALLOWED_HOSTS=db.internal:8529,backup.internal:8529
# SCHEMA_ANALYZER_CACHE_ROOT=/var/lib/schema-analyzer/cache

# LLM provider API keys (only set the one(s) you intend to use)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
