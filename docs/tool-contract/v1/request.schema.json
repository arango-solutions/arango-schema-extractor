{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arangodb.com/schema-analyzer/tool-contract/v1/request.schema.json",
  "title": "ArangoDB Schema Analyzer Tool Request (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "operation"],
  "properties": {
    "contractVersion": { "const": "1" },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "operation": { "type": "string", "enum": ["analyze", "snapshot", "export", "docs", "owl", "diff", "resolve", "csi"] },

    "connection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "database"],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048,
          "description": "ArangoDB URL, e.g. http://localhost:8529. Hosts may be restricted by setting SCHEMA_ANALYZER_ALLOWED_HOSTS in the server environment."
        },
        "database": { "type": "string", "minLength": 1, "maxLength": 256 },
        "username": { "type": "string", "maxLength": 256 },

        "password": { "type": "string", "maxLength": 1024, "description": "Prefer passwordEnvVar in agent workflows." },
        "passwordEnvVar": { "type": "string", "minLength": 1, "maxLength": 256 },

        "verifyTls": { "type": "boolean", "default": true }
      },
      "allOf": [
        {
          "not": {
            "allOf": [
              { "required": ["password"] },
              { "required": ["passwordEnvVar"] }
            ]
          }
        }
      ]
    },

    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "enum": ["openai", "anthropic", "openrouter"] },
        "model": { "type": "string", "maxLength": 256 },

        "apiKey": { "type": "string", "maxLength": 1024, "description": "Prefer apiKeyEnvVar in agent workflows." },
        "apiKeyEnvVar": { "type": "string", "minLength": 1, "maxLength": 256 },

        "systemPrompt": {
          "type": "string",
          "maxLength": 65536,
          "description": "Optional override; default is strict JSON-only. Hard limit 64 KiB to bound request size."
        },
        "promptVersion": { "type": "string", "maxLength": 256, "description": "Optional for cache keying/traceability." }
      },
      "allOf": [
        {
          "not": {
            "allOf": [
              { "required": ["apiKey"] },
              { "required": ["apiKeyEnvVar"] }
            ]
          }
        }
      ]
    },

    "analysisOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeoutMs": { "type": "integer", "minimum": 1000, "maximum": 600000, "default": 60000 },
        "sampleLimitPerCollection": { "type": "integer", "minimum": 0, "maximum": 1000, "default": 0 },
        "includeSamplesInSnapshot": { "type": "boolean", "default": false },

        "useCache": { "type": "boolean", "default": true },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["filesystem"] },
            "directory": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096,
              "description": "Cache directory path. When SCHEMA_ANALYZER_CACHE_ROOT is set in the server environment, this path (after resolution) must lie under that root or the request is rejected."
            }
          }
        },
        "cacheTtlSeconds": { "type": "integer", "minimum": 0, "maximum": 31536000, "default": 86400 },

        "reviewThreshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.6 },
        "maxRepairAttempts": { "type": "integer", "minimum": 0, "maximum": 10, "default": 2 },

        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "description": "Controls what is scrubbed from the physical snapshot before it is sent to the configured LLM provider (data egress). Has no effect on the no-LLM baseline path or on the local snapshot used for fingerprinting, baseline inference, reconciliation, and statistics.",
          "properties": {
            "stripSamples": {
              "type": "boolean",
              "default": false,
              "description": "Remove sampled documents/edges (sample_documents, sample_edges) from each collection before egress."
            },
            "maskFieldValues": {
              "type": "boolean",
              "default": false,
              "description": "Replace concrete values in sample_field_value_counts with opaque tokens, preserving field names, distinct-value counts, and frequencies."
            }
          }
        },
        "goldReference": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional gold reference for precision/recall scoring of the conceptual schema (PRD §3.12.3). A domain-pack-style object {entities:[{name}], relationships:[{type}]}. When present, the analyze result's metadata.qualityMetrics gains a 'gold' block and its overlap folds into healthScore.",
          "properties": {
            "entities": { "type": "array", "maxItems": 50000, "items": { "type": "object" } },
            "relationships": { "type": "array", "maxItems": 50000, "items": { "type": "object" } }
          }
        }
      }
    },

    "outputOptions": {
      "type": "object",
      "additionalProperties": false,
      "description": "Controls what the response payload includes. JSON serialization concerns (indentation, line endings, etc.) are the caller's responsibility and are NOT part of this contract.",
      "properties": {
        "includeSnapshot": {
          "type": "boolean",
          "default": false,
          "description": "When true, the analyze result includes the full snapshot under result.snapshot."
        },
        "includeSnapshotFingerprint": {
          "type": "boolean",
          "default": true,
          "description": "When false, tooling.snapshotFingerprint is omitted from the response. Default true preserves existing behavior."
        },
        "exportTarget": { "type": "string", "enum": ["cypher", "sparql"], "default": "cypher" },
        "owlFormat": {
          "type": "string",
          "enum": ["turtle", "jsonld"],
          "default": "turtle",
          "description": "Serialization for the owl operation. 'turtle' returns result.turtle; 'jsonld' returns result.jsonld."
        }
      }
    },

    "input": {
      "type": "object",
      "additionalProperties": false,
      "description": "Used for operations that transform existing analysis/snapshot payloads.",
      "properties": {
        "analysis": { "$ref": "#/$defs/AnalysisOutput" },
        "previousAnalysis": { "$ref": "#/$defs/AnalysisOutput" },
        "snapshot": { "$ref": "#/$defs/PhysicalSnapshot" }
      }
    }
  },

  "$defs": {
    "PhysicalSnapshot": {
      "type": "object",
      "description": "Physical schema snapshot as produced by snapshot_physical_schema(). Hosts that expose this contract to untrusted callers SHOULD enforce a request-body size cap at the transport layer (e.g. a few MiB); the analyzer treats nested fields as trusted snapshot data.",
      "additionalProperties": true
    },

    "AnalysisOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conceptualSchema", "physicalMapping", "metadata"],
      "properties": {
        "conceptualSchema": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entities", "relationships", "properties"],
          "properties": {
            "entities": { "type": "array", "maxItems": 50000, "items": { "type": "object" } },
            "relationships": { "type": "array", "maxItems": 50000, "items": { "type": "object" } },
            "properties": { "type": "array", "maxItems": 100000, "items": { "type": "object" } }
          }
        },
        "physicalMapping": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entities", "relationships"],
          "properties": {
            "entities": { "type": "object", "additionalProperties": { "type": "object" } },
            "relationships": { "type": "object", "additionalProperties": { "type": "object" } }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true,
          "required": ["confidence", "timestamp", "analyzedCollectionCounts", "detectedPatterns"],
          "properties": {
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "timestamp": { "type": "string", "maxLength": 64 },
            "analyzedCollectionCounts": {
              "type": "object",
              "additionalProperties": false,
              "required": ["documentCollections", "edgeCollections"],
              "properties": {
                "documentCollections": { "type": "number", "minimum": 0 },
                "edgeCollections": { "type": "number", "minimum": 0 }
              }
            },
            "detectedPatterns": { "type": "array", "maxItems": 1000, "items": { "type": "string", "maxLength": 256 } },
            "warnings": { "type": "array", "maxItems": 1000, "items": { "type": "string", "maxLength": 4096 } },
            "assumptions": { "type": "array", "maxItems": 1000, "items": { "type": "string", "maxLength": 4096 } }
          }
        }
      }
    }
  },

  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "analyze" } } },
      "then": { "required": ["connection"] }
    },
    {
      "if": { "properties": { "operation": { "const": "snapshot" } } },
      "then": { "required": ["connection"] }
    },
    {
      "if": { "properties": { "operation": { "enum": ["export", "docs", "owl", "resolve", "csi"] } } },
      "then": {
        "required": ["input"],
        "properties": {
          "input": { "required": ["analysis"] }
        }
      }
    },
    {
      "if": { "properties": { "operation": { "const": "diff" } } },
      "then": {
        "required": ["input"],
        "properties": {
          "input": { "required": ["analysis", "previousAnalysis"] }
        }
      }
    }
  ]
}
